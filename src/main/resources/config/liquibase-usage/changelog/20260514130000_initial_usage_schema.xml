    <changeSet id="20260514130000-1-create-usage-ingest-run" author="codex">
        <createTable schemaName="${usageSchemaName}" tableName="usage_ingest_run">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="s3_key" type="varchar(512)">
                <constraints nullable="false"/>
            </column>
            <column name="bucket_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="source_row_count" type="bigint"/>
            <column name="imported_at" type="datetime"/>
            <column name="error_message" type="clob"/>
            <column name="created_at" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint schemaName="${usageSchemaName}" tableName="usage_ingest_run" columnNames="s3_key" constraintName="uk_usage_ingest_run_s3_key"/>
        <addUniqueConstraint schemaName="${usageSchemaName}" tableName="usage_ingest_run" columnNames="bucket_date" constraintName="uk_usage_ingest_run_bucket_date"/>
    </changeSet>

